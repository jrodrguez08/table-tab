// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum RestaurantRole {
  OWNER
  ADMIN
  CASHIER
  WAITER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  DISABLED
}

enum SessionStatus {
  OPEN
  CLOSED
  CANCELED
}

enum TabStatus {
  OPEN
  CLOSED
}

enum OrderSource {
  POS
  TABLET
  WAITER
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  IN_KITCHEN
  READY
  SERVED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  VOIDED
  REFUNDED
}

enum AdjustmentScope {
  SESSION
  TAB
}

enum AdjustmentType {
  DISCOUNT
  SURCHARGE
}

enum AdjustmentMode {
  PERCENT
  FIXED
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id           String @id @default(uuid()) @db.Uuid
  email        String @unique
  passwordHash String @map("password_hash")

  isPlatformAdmin Boolean @default(false) @map("is_platform_admin")
  isActive        Boolean @default(true) @map("is_active")

  lastLoginAt DateTime? @map("last_login_at")

  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  deletedByUserId String?   @map("deleted_by_user_id") @db.Uuid
  deletedAt       DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships RestaurantUser[]

  // self audit
  createdBy User? @relation("UserCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy User? @relation("UserUpdatedBy", fields: [updatedByUserId], references: [id])
  deletedBy User? @relation("UserDeletedBy", fields: [deletedByUserId], references: [id])

  usersCreated User[] @relation("UserCreatedBy")
  usersUpdated User[] @relation("UserUpdatedBy")
  usersDeleted User[] @relation("UserDeletedBy")

  restaurantsCreated Restaurant[] @relation("RestaurantCreatedBy")
  restaurantsUpdated Restaurant[] @relation("RestaurantUpdatedBy")
  restaurantsDeleted Restaurant[] @relation("RestaurantDeletedBy")

  restaurantUsersCreated RestaurantUser[] @relation("RestaurantUserCreatedBy")
  restaurantUsersUpdated RestaurantUser[] @relation("RestaurantUserUpdatedBy")
  restaurantUsersRevoked RestaurantUser[] @relation("RestaurantUserRevokedBy")

  @@map("user")
}

//////////////////////////////////////////////////////
// RESTAURANT
//////////////////////////////////////////////////////

model Restaurant {
  id       String @id @default(uuid()) @db.Uuid
  slug     String @unique
  name     String
  currency String @default("CRC")
  timezone String @default("America/Costa_Rica")

  vatRate          Decimal @default(0.1300) @map("vat_rate") @db.Decimal(5, 4)
  serviceRate      Decimal @default(0.1000) @map("service_rate") @db.Decimal(5, 4)
  pricesIncludeVat Boolean @default(false) @map("prices_include_vat")

  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  deletedByUserId String?   @map("deleted_by_user_id") @db.Uuid
  deletedAt       DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tables     DiningTable[]
  sessions   TableSession[]
  products   Product[]
  categories Category[]
  users      RestaurantUser[]

  modifiers      Modifier[]
  modifierGroups ModifierGroup[]

  createdBy User? @relation("RestaurantCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy User? @relation("RestaurantUpdatedBy", fields: [updatedByUserId], references: [id])
  deletedBy User? @relation("RestaurantDeletedBy", fields: [deletedByUserId], references: [id])

  @@map("restaurant")
}

//////////////////////////////////////////////////////
// CATEGORY
//////////////////////////////////////////////////////

model Category {
  id           String @id @default(uuid()) @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid

  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  products   Product[]

  @@unique([restaurantId, name])
  @@index([restaurantId, sortOrder])
  @@map("category")
}

//////////////////////////////////////////////////////
// PRODUCT
//////////////////////////////////////////////////////

model Product {
  id           String  @id @default(uuid()) @db.Uuid
  restaurantId String  @map("restaurant_id") @db.Uuid
  categoryId   String? @map("category_id") @db.Uuid

  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  cost        Decimal? @db.Decimal(12, 2)

  imageUrl  String? @map("image_url")
  sortOrder Int     @default(0) @map("sort_order")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  restaurant        Restaurant             @relation(fields: [restaurantId], references: [id])
  category          Category?              @relation(fields: [categoryId], references: [id])
  orderItems        OrderItem[]
  modifierGroups    ProductModifierGroup[]
  modifierOverrides ProductModifier[]

  @@unique([restaurantId, name])
  @@map("product")
}

//////////////////////////////////////////////////////
// MODIFIERS
//////////////////////////////////////////////////////

model Modifier {
  id           String @id @default(uuid()) @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid

  name       String
  priceDelta Decimal  @default(0) @map("price_delta") @db.Decimal(12, 2)
  costDelta  Decimal? @map("cost_delta") @db.Decimal(12, 2)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  groups          ModifierGroupItem[]
  products        ProductModifier[]
  productDefaults ProductModifierDefault[]

  @@unique([restaurantId, name])
  @@map("modifier")
}

model ModifierGroup {
  id           String @id @default(uuid()) @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid

  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  minSelect Int @default(0) @map("min_select")
  maxSelect Int @default(99) @map("max_select")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  items    ModifierGroupItem[]
  products ProductModifierGroup[]

  @@unique([restaurantId, name])
  @@map("modifier_group")
}

model ModifierGroupItem {
  id         String @id @default(uuid()) @db.Uuid
  groupId    String @map("group_id") @db.Uuid
  modifierId String @map("modifier_id") @db.Uuid

  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  group    ModifierGroup @relation(fields: [groupId], references: [id])
  modifier Modifier      @relation(fields: [modifierId], references: [id])

  @@unique([groupId, modifierId])
  @@map("modifier_group_item")
}

model ProductModifierGroup {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  groupId   String @map("group_id") @db.Uuid

  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  product Product       @relation(fields: [productId], references: [id])
  group   ModifierGroup @relation(fields: [groupId], references: [id])

  defaults ProductModifierDefault[]

  @@unique([productId, groupId])
  @@map("product_modifier_group")
}

model ProductModifierDefault {
  id                     String @id @default(uuid()) @db.Uuid
  productModifierGroupId String @map("product_modifier_group_id") @db.Uuid
  modifierId             String @map("modifier_id") @db.Uuid

  qty       Decimal  @default(1) @db.Decimal(10, 3)
  createdAt DateTime @default(now()) @map("created_at")

  productModifierGroup ProductModifierGroup @relation(fields: [productModifierGroupId], references: [id])
  modifier             Modifier             @relation(fields: [modifierId], references: [id])

  @@unique([productModifierGroupId, modifierId])
  @@map("product_modifier_default")
}

model ProductModifier {
  id         String @id @default(uuid()) @db.Uuid
  productId  String @map("product_id") @db.Uuid
  modifierId String @map("modifier_id") @db.Uuid

  priceDeltaOverride Decimal? @map("price_delta_override") @db.Decimal(12, 2)
  costDeltaOverride  Decimal? @map("cost_delta_override") @db.Decimal(12, 2)

  isActive Boolean @default(true) @map("is_active")

  product  Product  @relation(fields: [productId], references: [id])
  modifier Modifier @relation(fields: [modifierId], references: [id])

  @@unique([productId, modifierId])
  @@map("product_modifier")
}

//////////////////////////////////////////////////////
// TABLES & SESSIONS
//////////////////////////////////////////////////////

model DiningTable {
  id           String      @id @default(uuid()) @db.Uuid
  restaurantId String      @db.Uuid
  name         String
  status       TableStatus @default(AVAILABLE)
  createdAt    DateTime    @default(now())

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  sessions   TableSession[]
  qrs        DiningTableQr[]

  @@unique([restaurantId, name])
  @@map("dining_table")
}

model DiningTableQr {
  id         String   @id @default(uuid()) @db.Uuid
  tableId    String   @map("table_id") @db.Uuid
  publicCode String   @unique @map("public_code")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  table DiningTable @relation(fields: [tableId], references: [id])

  @@index([tableId])
  @@map("dining_table_qr")
}

model TableSession {
  id           String        @id @default(uuid()) @db.Uuid
  restaurantId String        @db.Uuid
  tableId      String        @db.Uuid
  status       SessionStatus @default(OPEN)
  openedAt     DateTime      @default(now())
  closedAt     DateTime?

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  table      DiningTable @relation(fields: [tableId], references: [id])

  tabs        TableSessionTab[]
  orders      Order[]
  payments    Payment[]
  adjustments SessionAdjustment[]

  @@map("table_session")
}

model TableSessionTab {
  id             String    @id @default(uuid()) @db.Uuid
  tableSessionId String    @db.Uuid
  label          String
  status         TabStatus @default(OPEN)
  createdAt      DateTime  @default(now())
  closedAt       DateTime?

  session     TableSession          @relation(fields: [tableSessionId], references: [id])
  payments    Payment[]
  allocations OrderItemAllocation[]
  adjustments SessionAdjustment[]

  @@map("table_session_tab")
}

model SessionAdjustment {
  id             String          @id @default(uuid()) @db.Uuid
  tableSessionId String          @map("table_session_id") @db.Uuid
  tabId          String?         @map("tab_id") @db.Uuid
  scope          AdjustmentScope
  type           AdjustmentType
  mode           AdjustmentMode
  value          Decimal         @db.Decimal(12, 2)
  reason         String?
  createdAt      DateTime        @default(now()) @map("created_at")

  session TableSession     @relation(fields: [tableSessionId], references: [id])
  tab     TableSessionTab? @relation(fields: [tabId], references: [id])

  @@index([tableSessionId])
  @@index([tabId])
  @@map("session_adjustment")
}

//////////////////////////////////////////////////////
// ORDERS
//////////////////////////////////////////////////////

model Order {
  id             String      @id @default(uuid()) @db.Uuid
  restaurantId   String      @db.Uuid
  tableSessionId String      @db.Uuid
  source         OrderSource
  status         OrderStatus @default(DRAFT)
  createdAt      DateTime    @default(now())

  session TableSession @relation(fields: [tableSessionId], references: [id])
  items   OrderItem[]

  @@map("order")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid
  productId String? @db.Uuid

  nameSnapshot String
  qty          Decimal  @db.Decimal(10, 3)
  unitPrice    Decimal  @db.Decimal(12, 2)
  unitCost     Decimal? @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  order       Order                 @relation(fields: [orderId], references: [id])
  product     Product?              @relation(fields: [productId], references: [id])
  modifiers   OrderItemModifier[]
  allocations OrderItemAllocation[]

  @@map("order_item")
}

model OrderItemModifier {
  id           String   @id @default(uuid()) @db.Uuid
  orderItemId  String   @db.Uuid
  nameSnapshot String
  priceDelta   Decimal  @db.Decimal(12, 2)
  costDelta    Decimal? @db.Decimal(12, 2)
  qty          Decimal  @default(1) @db.Decimal(10, 3)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("order_item_modifier")
}

model OrderItemAllocation {
  id          String   @id @default(uuid()) @db.Uuid
  orderItemId String   @map("order_item_id") @db.Uuid
  tabId       String   @map("tab_id") @db.Uuid
  qty         Decimal  @db.Decimal(10, 3)
  createdAt   DateTime @default(now()) @map("created_at")

  orderItem OrderItem       @relation(fields: [orderItemId], references: [id])
  tab       TableSessionTab @relation(fields: [tabId], references: [id])

  @@unique([orderItemId, tabId])
  @@index([tabId])
  @@index([orderItemId])
  @@map("order_item_allocation")
}

//////////////////////////////////////////////////////
// PAYMENTS
//////////////////////////////////////////////////////

model Payment {
  id             String  @id @default(uuid()) @db.Uuid
  tableSessionId String  @map("table_session_id") @db.Uuid
  tabId          String? @map("tab_id") @db.Uuid

  amount      Decimal       @db.Decimal(12, 2)
  method      String
  status      PaymentStatus @default(PAID)
  providerRef String?       @map("provider_ref")
  createdAt   DateTime      @default(now()) @map("created_at")

  session TableSession     @relation(fields: [tableSessionId], references: [id])
  tab     TableSessionTab? @relation(fields: [tabId], references: [id])

  @@index([tableSessionId])
  @@index([tabId])
  @@map("payment")
}

//////////////////////////////////////////////////////
// RESTAURANT USER
//////////////////////////////////////////////////////

model RestaurantUser {
  id           String         @id @default(uuid()) @db.Uuid
  restaurantId String         @db.Uuid
  userId       String         @db.Uuid
  role         RestaurantRole

  isActive Boolean @default(true)

  createdByUserId String?   @db.Uuid
  updatedByUserId String?   @db.Uuid
  revokedByUserId String?   @db.Uuid
  revokedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  createdBy User? @relation("RestaurantUserCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy User? @relation("RestaurantUserUpdatedBy", fields: [updatedByUserId], references: [id])
  revokedBy User? @relation("RestaurantUserRevokedBy", fields: [revokedByUserId], references: [id])

  @@unique([restaurantId, userId])
  @@map("restaurant_user")
}
