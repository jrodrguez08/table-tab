// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  DISABLED
}

enum SessionStatus {
  OPEN
  CLOSED
  CANCELED
}

enum TabStatus {
  OPEN
  CLOSED
}

enum OrderSource {
  POS
  TABLET
  WAITER
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  IN_KITCHEN
  READY
  SERVED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  VOIDED
  REFUNDED
}

enum AdjustmentScope {
  SESSION
  TAB
}

enum AdjustmentType {
  DISCOUNT
  SURCHARGE
}

enum AdjustmentMode {
  PERCENT
  FIXED
}

enum ModifierGroupSelectMode {
  OPTIONAL // 0..max
  REQUIRED // min>=1
}

model Restaurant {
  id       String @id @default(uuid()) @db.Uuid
  slug     String @unique
  name     String
  currency String @default("CRC")
  timezone String @default("America/Costa_Rica")

  vatRate          Decimal @default(0.1300) @map("vat_rate") @db.Decimal(5, 4)
  serviceRate      Decimal @default(0.1000) @map("service_rate") @db.Decimal(5, 4)
  pricesIncludeVat Boolean @default(false) @map("prices_include_vat")

  createdAt DateTime @default(now()) @map("created_at")

  tables         DiningTable[]
  sessions       TableSession[]
  products       Product[]
  categories     Category[]
  modifiers      Modifier[]
  modifierGroups ModifierGroup[]

  @@map("restaurant")
}

model Category {
  id           String @id @default(uuid()) @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid

  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  products   Product[]

  @@unique([restaurantId, name])
  @@index([restaurantId, sortOrder])
  @@map("category")
}

model Product {
  id           String  @id @default(uuid()) @db.Uuid
  restaurantId String  @map("restaurant_id") @db.Uuid
  categoryId   String? @map("category_id") @db.Uuid // NUEVO (nullable para migrar fácil)

  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  cost        Decimal? @db.Decimal(12, 2)

  imageUrl  String? @map("image_url") // opcional (útil en menú)
  sortOrder Int     @default(0) @map("sort_order") // opcional (orden dentro de categoría)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  restaurant        Restaurant             @relation(fields: [restaurantId], references: [id])
  category          Category?              @relation(fields: [categoryId], references: [id]) // NUEVO
  orderItems        OrderItem[]
  modifierGroups    ProductModifierGroup[]
  modifierOverrides ProductModifier[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([restaurantId, categoryId, sortOrder]) // NUEVO
  @@map("product")
}

model Modifier {
  id           String @id @default(uuid()) @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid

  name       String
  priceDelta Decimal  @default(0) @map("price_delta") @db.Decimal(12, 2)
  costDelta  Decimal? @map("cost_delta") @db.Decimal(12, 2)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  // relaciones
  groups          ModifierGroupItem[]
  products        ProductModifier[]
  productDefaults ProductModifierDefault[]

  @@unique([restaurantId, name])
  @@index([restaurantId, isActive])
  @@map("modifier")
}

model ModifierGroup {
  id           String @id @default(uuid()) @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid

  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  // reglas
  minSelect Int @default(0) @map("min_select")
  maxSelect Int @default(99) @map("max_select")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  items    ModifierGroupItem[]
  products ProductModifierGroup[]

  @@unique([restaurantId, name])
  @@index([restaurantId, sortOrder])
  @@map("modifier_group")
}

model ModifierGroupItem {
  id         String @id @default(uuid()) @db.Uuid
  groupId    String @map("group_id") @db.Uuid
  modifierId String @map("modifier_id") @db.Uuid

  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  group    ModifierGroup @relation(fields: [groupId], references: [id])
  modifier Modifier      @relation(fields: [modifierId], references: [id])

  @@unique([groupId, modifierId])
  @@index([groupId, sortOrder])
  @@index([modifierId])
  @@map("modifier_group_item")
}

model ProductModifierGroup {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  groupId   String @map("group_id") @db.Uuid

  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  product Product       @relation(fields: [productId], references: [id])
  group   ModifierGroup @relation(fields: [groupId], references: [id])

  defaults ProductModifierDefault[]

  @@unique([productId, groupId])
  @@index([productId, sortOrder])
  @@index([groupId])
  @@map("product_modifier_group")
}

model ProductModifierDefault {
  id                     String @id @default(uuid()) @db.Uuid
  productModifierGroupId String @map("product_modifier_group_id") @db.Uuid
  modifierId             String @map("modifier_id") @db.Uuid

  qty       Decimal  @default(1) @db.Decimal(10, 3)
  createdAt DateTime @default(now()) @map("created_at")

  productModifierGroup ProductModifierGroup @relation(fields: [productModifierGroupId], references: [id])
  modifier             Modifier             @relation(fields: [modifierId], references: [id])

  @@unique([productModifierGroupId, modifierId])
  @@index([modifierId])
  @@map("product_modifier_default")
}

model ProductModifier {
  id         String @id @default(uuid()) @db.Uuid
  productId  String @map("product_id") @db.Uuid
  modifierId String @map("modifier_id") @db.Uuid

  // overrides opcionales
  priceDeltaOverride Decimal? @map("price_delta_override") @db.Decimal(12, 2)
  costDeltaOverride  Decimal? @map("cost_delta_override") @db.Decimal(12, 2)

  isActive Boolean @default(true) @map("is_active")

  product  Product  @relation(fields: [productId], references: [id])
  modifier Modifier @relation(fields: [modifierId], references: [id])

  @@unique([productId, modifierId])
  @@index([productId])
  @@index([modifierId])
  @@map("product_modifier")
}

model DiningTable {
  id           String      @id @default(uuid()) @db.Uuid
  restaurantId String      @map("restaurant_id") @db.Uuid
  name         String
  status       TableStatus @default(AVAILABLE)
  createdAt    DateTime    @default(now()) @map("created_at")

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  qrs        DiningTableQr[]
  sessions   TableSession[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("dining_table")
}

model DiningTableQr {
  id         String   @id @default(uuid()) @db.Uuid
  tableId    String   @map("table_id") @db.Uuid
  publicCode String   @unique @map("public_code")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  table DiningTable @relation(fields: [tableId], references: [id])

  @@index([tableId])
  @@map("dining_table_qr")
}

model TableSession {
  id           String        @id @default(uuid()) @db.Uuid
  restaurantId String        @map("restaurant_id") @db.Uuid
  tableId      String        @map("table_id") @db.Uuid
  publicCode   String?       @unique @map("public_code") // optional if you later use session QR
  status       SessionStatus @default(OPEN)
  guestsCount  Int?          @map("guests_count")
  openedAt     DateTime      @default(now()) @map("opened_at")
  closedAt     DateTime?     @map("closed_at")

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  table      DiningTable @relation(fields: [tableId], references: [id])

  tabs        TableSessionTab[]
  orders      Order[]
  payments    Payment[]
  adjustments SessionAdjustment[]

  @@index([restaurantId])
  @@index([tableId, status])
  @@map("table_session")
}

model TableSessionTab {
  id             String    @id @default(uuid()) @db.Uuid
  tableSessionId String    @map("table_session_id") @db.Uuid
  label          String
  status         TabStatus @default(OPEN)
  createdAt      DateTime  @default(now()) @map("created_at")
  closedAt       DateTime? @map("closed_at")

  session     TableSession          @relation(fields: [tableSessionId], references: [id])
  allocations OrderItemAllocation[]
  payments    Payment[]
  adjustments SessionAdjustment[]

  @@unique([tableSessionId, label])
  @@index([tableSessionId])
  @@map("table_session_tab")
}

model Order {
  id             String      @id @default(uuid()) @db.Uuid
  restaurantId   String      @map("restaurant_id") @db.Uuid
  tableSessionId String      @map("table_session_id") @db.Uuid
  source         OrderSource
  status         OrderStatus @default(DRAFT)
  createdAt      DateTime    @default(now()) @map("created_at")

  session TableSession @relation(fields: [tableSessionId], references: [id])
  items   OrderItem[]

  @@index([tableSessionId])
  @@index([restaurantId])
  @@map("order")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @map("order_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid

  nameSnapshot String   @map("name_snapshot")
  qty          Decimal  @db.Decimal(10, 3)
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 2)
  unitCost     Decimal? @map("unit_cost") @db.Decimal(12, 2) //

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  order       Order                 @relation(fields: [orderId], references: [id])
  product     Product?              @relation(fields: [productId], references: [id]) //
  modifiers   OrderItemModifier[]
  allocations OrderItemAllocation[]

  @@index([orderId])
  @@index([productId])
  @@map("order_item")
}

model OrderItemModifier {
  id           String  @id @default(uuid()) @db.Uuid
  orderItemId  String  @map("order_item_id") @db.Uuid
  nameSnapshot String  @map("name_snapshot")
  priceDelta   Decimal @map("price_delta") @db.Decimal(12, 2)

  costDelta Decimal? @map("cost_delta") @db.Decimal(12, 2)

  qty Decimal @default(1) @db.Decimal(10, 3)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([orderItemId])
  @@map("order_item_modifier")
}

model OrderItemAllocation {
  id          String   @id @default(uuid()) @db.Uuid
  orderItemId String   @map("order_item_id") @db.Uuid
  tabId       String   @map("tab_id") @db.Uuid
  qty         Decimal  @db.Decimal(10, 3)
  createdAt   DateTime @default(now()) @map("created_at")

  orderItem OrderItem       @relation(fields: [orderItemId], references: [id])
  tab       TableSessionTab @relation(fields: [tabId], references: [id])

  @@unique([orderItemId, tabId])
  @@index([tabId])
  @@map("order_item_allocation")
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  tableSessionId String        @map("table_session_id") @db.Uuid
  tabId          String?       @map("tab_id") @db.Uuid
  amount         Decimal       @db.Decimal(12, 2)
  method         String
  status         PaymentStatus @default(PAID)
  providerRef    String?       @map("provider_ref")
  createdAt      DateTime      @default(now()) @map("created_at")

  session TableSession     @relation(fields: [tableSessionId], references: [id])
  tab     TableSessionTab? @relation(fields: [tabId], references: [id])

  @@index([tableSessionId])
  @@index([tabId])
  @@map("payment")
}

model SessionAdjustment {
  id             String          @id @default(uuid()) @db.Uuid
  tableSessionId String          @map("table_session_id") @db.Uuid
  tabId          String?         @map("tab_id") @db.Uuid
  scope          AdjustmentScope
  type           AdjustmentType
  mode           AdjustmentMode
  value          Decimal         @db.Decimal(12, 2)
  reason         String?
  createdAt      DateTime        @default(now()) @map("created_at")

  session TableSession     @relation(fields: [tableSessionId], references: [id])
  tab     TableSessionTab? @relation(fields: [tabId], references: [id])

  @@index([tableSessionId])
  @@index([tabId])
  @@map("session_adjustment")
}
