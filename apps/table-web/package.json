    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
